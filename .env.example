# Optional access protection. Add as Space Secrets.
APP_PASSWORD=
SESSION_SECRET=

# Provider/API configuration.
# Users can choose provider and model directly in the UI; the server does not force a fixed provider or model.
HF_TOKEN=

# Optional GitHub backup. Repository format: owner/repo
GITHUB_TOKEN=
GITHUB_BACKUP_REPO=thrdchld/ghostwriter-backup
SYNC_DEBOUNCE_SECONDS=45

# Optional internet reference search.
TAVILY_API_KEY=

