# Required for AI generation. Add as a Hugging Face Space Secret.
HF_TOKEN=

# Optional access protection. Add as Space Secrets.
APP_PASSWORD=
SESSION_SECRET=

# Model and provider configuration.
HF_MODEL=Qwen/Qwen3-4B-Instruct-2507
HF_FALLBACK_MODELS=Qwen/Qwen3-8B,mistralai/Mistral-7B-Instruct-v0.3
HF_INFERENCE_PROVIDER=auto

# Optional GitHub backup. Repository format: owner/repo
GITHUB_TOKEN=
GITHUB_BACKUP_REPO=thrdchld/ghostwriter-backup
SYNC_DEBOUNCE_SECONDS=45

# Optional internet reference search.
TAVILY_API_KEY=

